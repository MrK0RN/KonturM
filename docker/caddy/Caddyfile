# Обратный прокси к Symfony (встроенный PHP-сервер на :8000 внутри сети compose).
# HTTP :80 и HTTPS :443. На 443 по умолчанию — встроенный сертификат Caddy (tls internal).
# Для публичного домена с Let's Encrypt замените блоки :80 / :443 на имя сайта, см. Caddyfile.domain-example

(common) {
	encode gzip zstd
	reverse_proxy app:8000 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Port {server_port}
	}
}

# HTTP
:80 {
	import common
}

# HTTPS (слушает 443)
:443 {
	tls internal
	import common
}
